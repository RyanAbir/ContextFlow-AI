rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for workspace authorization
    function isSignedIn() {
      return request.auth != null;
    }

    function isWorkspaceOwner(workspaceId) {
      return isSignedIn() && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
    }

    function isWorkspaceMemberDoc(workspaceId) {
      return isSignedIn() && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function isWorkspaceAdmin(workspaceId) {
      return isWorkspaceOwner(workspaceId)
        || (
          isSignedIn()
          && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid))
          && get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role == 'admin'
        );
    }

    function canReadWorkspace(workspaceId) {
      return isWorkspaceOwner(workspaceId) || isWorkspaceMemberDoc(workspaceId);
    }

    function canManageWorkspace(workspaceId) {
      return isWorkspaceOwner(workspaceId) || isWorkspaceAdmin(workspaceId);
    }

    function isInviteWorkspaceAdmin() {
      return resource.data.workspaceId != null && isWorkspaceAdmin(resource.data.workspaceId);
    }

    function isInviteRecipient() {
      return request.auth.token.email != null
        && resource.data.invitedEmail == request.auth.token.email;
    }

    function queryFilterValue(fieldName) {
      return request.query.where.size() > 0 && request.query.where[0].field == fieldName
        ? request.query.where[0].value
        : request.query.where.size() > 1 && request.query.where[1].field == fieldName
          ? request.query.where[1].value
          : null;
    }

    function queryFilterOp(fieldName) {
      return request.query.where.size() > 0 && request.query.where[0].field == fieldName
        ? request.query.where[0].op
        : request.query.where.size() > 1 && request.query.where[1].field == fieldName
          ? request.query.where[1].op
          : null;
    }

    function isInviteWorkspaceAdminQuery() {
      let workspaceId = queryFilterValue('workspaceId');
      return request.auth != null
        && workspaceId is string
        && queryFilterOp('workspaceId') == '=='
        && isWorkspaceAdmin(workspaceId);
    }

    function isInviteRecipientQuery() {
      return request.auth.token.email != null
        && queryFilterValue('invitedEmail') == request.auth.token.email
        && queryFilterOp('invitedEmail') == '==';
    }

    function isPendingInviteForRequest(inviteId, workspaceId) {
      return request.auth.token.email != null
        && exists(/databases/$(database)/documents/workspaceInvites/$(inviteId))
        && get(/databases/$(database)/documents/workspaceInvites/$(inviteId)).data.workspaceId == workspaceId
        && get(/databases/$(database)/documents/workspaceInvites/$(inviteId)).data.invitedEmail == request.auth.token.email
        && get(/databases/$(database)/documents/workspaceInvites/$(inviteId)).data.role == request.resource.data.role
        && get(/databases/$(database)/documents/workspaceInvites/$(inviteId)).data.status == 'pending';
    }

    // Default: Deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection: Allow users to read/write only their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Collection-group membership lookup for the workspace switcher.
    // Users may only read membership documents that identify themselves.
    match /{workspacePath=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Workspaces collection: owner-controlled with member read access
    match /workspaces/{workspaceId} {
      // Create only when ownerId equals the authenticated user
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Read by owner or any workspace member
      allow read: if isWorkspaceOwner(workspaceId) || isWorkspaceMemberDoc(workspaceId);

      // Only owner may update or delete the workspace
      allow update: if isWorkspaceOwner(workspaceId);
      allow delete: if isWorkspaceOwner(workspaceId);

      // Members subcollection
      match /members/{memberId} {
        // Members can read their own member doc; owner can read all
        allow read: if isWorkspaceOwner(workspaceId) || (isSignedIn() && request.auth.uid == memberId);

        // Owner can create/update/delete member docs
        allow create, update, delete: if isWorkspaceOwner(workspaceId);

        // Allow a user to create their own owner member doc when creating their workspace
        allow create: if isSignedIn() && request.auth.uid == memberId
          && request.resource.data.keys().hasOnly(['userId', 'workspaceId', 'role', 'joinedAt'])
          && request.resource.data.workspaceId == workspaceId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.role == 'owner';

        // Allow an invited user to create only their own member doc from a pending invite
        allow create: if isSignedIn()
          && request.auth.uid == memberId
          && request.resource.data.keys().hasOnly(['userId', 'workspaceId', 'role', 'joinedAt', 'inviteId'])
          && request.resource.data.workspaceId == workspaceId
          && request.resource.data.userId == request.auth.uid
          && (request.resource.data.role == 'admin' || request.resource.data.role == 'member')
          && request.resource.data.inviteId is string
          && isPendingInviteForRequest(request.resource.data.inviteId, workspaceId);
      }
    }

    match /tasks/{taskId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.projectId is string
        && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.userId == request.auth.uid;

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /contextNotes/{noteId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.projectId is string
        && get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.userId == request.auth.uid;

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Projects collection: supports personal projects and workspace-owned projects
    match /projects/{projectId} {
      // Create: allow personal project creation or workspace project creation by workspace members
      allow create: if isSignedIn() && (
        // Personal project
        (request.resource.data.userId == request.auth.uid)
        // Workspace project: workspaceId provided, user is member, and createdBy matches requester
        || (
          request.resource.data.workspaceId != null
          && request.resource.data.createdBy == request.auth.uid
          && isWorkspaceMemberDoc(request.resource.data.workspaceId)
        )
      );

      // Read: personal owners or workspace members
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid)
        || (resource.data.workspaceId != null && canReadWorkspace(resource.data.workspaceId))
      );

      // Update: personal owners or workspace managers (owner/admin)
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid)
        || (resource.data.workspaceId != null && canManageWorkspace(resource.data.workspaceId))
      );

      // Delete: personal owners or workspace managers
      allow delete: if isSignedIn() && (
        (resource.data.userId == request.auth.uid)
        || (resource.data.workspaceId != null && canManageWorkspace(resource.data.workspaceId))
      );

      // Tasks subcollection: keep existing rules (personal-project logic remains)
      match /tasks/{taskId} {
        allow read: if request.auth != null && get(/databases/(default)/documents/projects/{projectId}).data.userId == request.auth.uid;
        allow create, update, delete: if request.auth != null && get(/databases/(default)/documents/projects/{projectId}).data.userId == request.auth.uid;
      }

      // Context Notes subcollection: keep existing rules (personal-project logic remains)
      match /contextNotes/{noteId} {
        allow read: if request.auth != null && get(/databases/(default)/documents/projects/{projectId}).data.userId == request.auth.uid;
        allow create, update, delete: if request.auth != null && get(/databases/(default)/documents/projects/{projectId}).data.userId == request.auth.uid;
      }
    }

    // Workspace invites: stored at /workspaceInvites/{inviteId}
    match /workspaceInvites/{inviteId} {
      // Create: only workspace owner or admin may create an invite for their workspace
      allow create: if isSignedIn()
        && request.resource.data.workspaceId != null
        && isWorkspaceAdmin(request.resource.data.workspaceId)
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.invitedEmail != null
        && request.resource.data.status == 'pending';

      // Read: workspace owner/admin can query invites for their workspace;
      // invited users can query invites addressed to their email.
      allow get: if isSignedIn() && (isInviteWorkspaceAdmin() || isInviteRecipient());
      allow list: if isSignedIn() && (isInviteWorkspaceAdminQuery() || isInviteRecipientQuery());

      // Update: invited user may only change `status` (accept/decline) and nothing else;
      // workspace admin/owner may update (e.g., cancel) the invite
      allow update: if isSignedIn() && (
        // invited user accepting/declining: only status may change to accepted/declined
        (
          request.auth.token.email != null
          && resource.data.invitedEmail == request.auth.token.email
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'acceptedBy', 'declinedAt', 'declinedBy'])
          && request.resource.data.workspaceId == resource.data.workspaceId
          && request.resource.data.workspaceName == resource.data.workspaceName
          && request.resource.data.invitedEmail == resource.data.invitedEmail
          && request.resource.data.invitedBy == resource.data.invitedBy
          && request.resource.data.role == resource.data.role
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.expiresAt == resource.data.expiresAt
          && (
            (
              request.resource.data.status == 'accepted'
              && request.resource.data.acceptedBy == request.auth.uid
              && !('declinedBy' in request.resource.data)
              && !('declinedAt' in request.resource.data)
            )
            || (
              request.resource.data.status == 'declined'
              && request.resource.data.declinedBy == request.auth.uid
              && !('acceptedBy' in request.resource.data)
              && !('acceptedAt' in request.resource.data)
            )
          )
        )
        // owner/admin may update any field on the invite
        || isInviteWorkspaceAdmin()
      );

      // Delete: only workspace owner/admin may delete invites
      allow delete: if isSignedIn() && isInviteWorkspaceAdmin();
    }
  }
}
