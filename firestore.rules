rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for workspace authorization
    function isSignedIn() {
      return request.auth != null;
    }

    function isWorkspaceOwner(workspaceId) {
      return isSignedIn() && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
    }

    function isWorkspaceMember(workspaceId) {
      return isSignedIn() && get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).exists();
    }

    function isWorkspaceAdmin(workspaceId) {
      if (!isSignedIn()) { return false; }
      if (isWorkspaceOwner(workspaceId)) { return true; }
      let member = get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
      return member.exists() && member.data.role == 'admin';
    }

    function canReadWorkspace(workspaceId) {
      return isWorkspaceOwner(workspaceId) || isWorkspaceMember(workspaceId);
    }

    function canManageWorkspace(workspaceId) {
      return isWorkspaceOwner(workspaceId) || isWorkspaceAdmin(workspaceId);
    }

    // Default: Deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection: Allow users to read/write only their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Workspaces collection: owner-controlled with member read access
    match /workspaces/{workspaceId} {
      // Create only when ownerId equals the authenticated user
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Read by owner or any workspace member
      allow read: if isWorkspaceOwner(workspaceId) || isWorkspaceMember(workspaceId);

      // Only owner may update or delete the workspace
      allow update: if isWorkspaceOwner(workspaceId);
      allow delete: if isWorkspaceOwner(workspaceId);

      // Members subcollection
      match /members/{memberId} {
        // Members can read their own member doc; owner can read all
        allow read: if isWorkspaceOwner(workspaceId) || (isSignedIn() && request.auth.uid == memberId);

        // Owner can create/update/delete member docs
        allow create, update, delete: if isWorkspaceOwner(workspaceId);

        // Allow a user to create their own owner member doc when creating their workspace
        allow create: if isSignedIn() && request.auth.uid == memberId
          && request.resource.data.workspaceId == workspaceId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.role == 'owner';
      }
    }

    // Projects collection: supports personal projects and workspace-owned projects
    match /projects/{projectId} {
      // Create: allow personal project creation or workspace project creation by workspace members
      allow create: if isSignedIn() && (
        // Personal project
        (request.resource.data.userId == request.auth.uid)
        // Workspace project: workspaceId provided, user is member, and createdBy matches requester
        || (
          request.resource.data.workspaceId != null
          && request.resource.data.createdBy == request.auth.uid
          && isWorkspaceMember(request.resource.data.workspaceId)
        )
      );

      // Read: personal owners or workspace members
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid)
        || (resource.data.workspaceId != null && canReadWorkspace(resource.data.workspaceId))
      );

      // Update: personal owners or workspace managers (owner/admin)
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid)
        || (resource.data.workspaceId != null && canManageWorkspace(resource.data.workspaceId))
      );

      // Delete: personal owners or workspace managers
      allow delete: if isSignedIn() && (
        (resource.data.userId == request.auth.uid)
        || (resource.data.workspaceId != null && canManageWorkspace(resource.data.workspaceId))
      );

      // Tasks subcollection: keep existing rules (personal-project logic remains)
      match /tasks/{taskId} {
        allow read: if request.auth != null && get(/databases/(default)/documents/projects/{projectId}).data.userId == request.auth.uid;
        allow create, update, delete: if request.auth != null && get(/databases/(default)/documents/projects/{projectId}).data.userId == request.auth.uid;
      }

      // Context Notes subcollection: keep existing rules (personal-project logic remains)
      match /contextNotes/{noteId} {
        allow read: if request.auth != null && get(/databases/(default)/documents/projects/{projectId}).data.userId == request.auth.uid;
        allow create, update, delete: if request.auth != null && get(/databases/(default)/documents/projects/{projectId}).data.userId == request.auth.uid;
      }
    }
  }
}
